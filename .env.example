# PostgreSQL connection string
# 로컬 Docker:  postgresql://postgres:postgres@localhost:5432/outsourcing?schema=public
# Neon/Supabase: 콘솔에서 발급받은 connection string 사용
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/outsourcing?schema=public"

# NextAuth (Auth.js)
# AUTH_SECRET: `npx auth secret` 또는 `openssl rand -base64 32` 로 생성
AUTH_SECRET="replace-with-strong-random-string"
# 배포 시 실제 도메인 (예: https://outsourcing.example.com), 로컬은 비워둬도 됨
AUTH_URL="http://localhost:3000"
# Trust host header (Vercel/대부분의 호스팅 환경에서 필요)
AUTH_TRUST_HOST="true"

# Google OAuth credentials
# https://console.cloud.google.com/ → APIs & Services → Credentials → OAuth 2.0 Client ID
# Authorized redirect URI: {AUTH_URL}/api/auth/callback/google
AUTH_GOOGLE_ID=""
AUTH_GOOGLE_SECRET=""

# 접근 제어 (둘 다 비우면 누구나 로그인 가능 - 운영 시 반드시 설정)
# 콤마로 여러 개 지정 가능
AUTH_ALLOWED_DOMAINS="example.com"
AUTH_ALLOWED_EMAILS=""

# 관리자 자동 승격: 여기 명시된 이메일로 로그인하면 자동으로 ADMIN 역할 부여
# 최초 운영자 부트스트랩용. 콤마로 여러 명 지정 가능.
AUTH_ADMIN_EMAILS=""
